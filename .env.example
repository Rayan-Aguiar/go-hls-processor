POSTGRES_CONTAINER_NAME=video-processor-postgres
POSTGRES_USER=videoproc
POSTGRES_PASSWORD=videoproc
POSTGRES_DB=video_processor
POSTGRES_PORT=5432

DATABASE_URL=postgres://videoproc:videoproc@localhost:5432/video_processor?sslmode=disable
DATA_DIR=./data
MIGRATIONS_DIR=./migrations
PORT=8000

# Redis
REDIS_CONTAINER_NAME=video-processor-redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=videoproc2024
REDIS_DB=0

# Graphics / admin
GRAFANA_CONTAINER_NAME=video-processor-grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Prometheus / exporters
PROMETHEUS_CONTAINER_NAME=video-processor-prometheus
PROMETHEUS_PORT=9090
POSTGRES_EXPORTER_CONTAINER_NAME=video-processor-postgres-exporter
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_CONTAINER_NAME=video-processor-redis-exporter
REDIS_EXPORTER_PORT=9121

# Application metrics
WORKER_METRICS_PORT=9101
METRICS_SAMPLE_INTERVAL_SECONDS=5

# Queue / worker
QUEUE_NAME=video:jobs
RETRY_QUEUE=video:jobs:retry
DEAD_LETTER_QUEUE=video:jobs:dead
WORKER_POOL_SIZE=4
WORKER_BUFFER_SIZE=12
WORKER_TIMEOUT_MINUTES=30
QUEUE_DEQUEUE_TIMEOUT_SECONDS=2
QUEUE_BATCH_SIZE=20
QUEUE_POLL_INTERVAL_MS=500
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=5
RETRY_BACKOFF_MAX_SECONDS=300
RETRY_SWEEP_INTERVAL_SECONDS=1
RETRY_MOVE_BATCH=100
RECOVERY_SWEEP_INTERVAL_SECONDS=5
RECOVERY_STUCK_AFTER_SECONDS=120
RECOVERY_BATCH_SIZE=100